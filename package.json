{
  "name": "tabtimer",
  "private": true,
  "version": "1.0.0",
  "description": "A chrome extension to help you watch how much time you've spent on a website as an overlay.",
  "type": "module",
  "author": "Cory Gabrielsen <corygabrielsen@gmail.com>",
  "license": "MIT",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build && vite build --config vite.content.config.ts",
    "watch": "vite build --watch",
    "package": "pnpm run build && cd dist && zip -r ../tabtimer.zip . -x '.vite/*'",
    "clean": "rm -rf dist tabtimer.zip",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"vite.config.ts\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0",
    "@eslint/js": "^9.17.0",
    "@types/chrome": "^0.0.304",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0",
    "vite": "^6.0.6",
    "vitest": "^4.1.9"
  }
}
