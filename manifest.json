{
  "manifest_version": 3,
  "name": "Tab Timer",
  "description": "Watch how much time you've spent on a website today.",
  "version": "1.0",
  "icons": {
    "32": "favicon32.png",
    "64": "favicon64.png",
    "128": "favicon128.png"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "*://blank.org/*",
    "*://*.discord.com/*",
    "*://*.discordapp.com/*",
    "*://*.facebook.com/*",
    "*://*.instagram.com/*",
    "*://*.linkedin.com/*",
    "*://*.pinterest.com/*",
    "*://*.messenger.com/*",
    "*://*.quora.com/*",
    "*://*.reddit.com/*",
    "*://*.slack.com/*",
    "*://*.snapchat.com/*",
    "*://*.telegram.org/*",
    "*://*.tiktok.com/*",
    "*://*.twitch.tv/*",
    "*://*.twitter.com/*",
    "*://*.tumblr.com/*",
    "*://*.whatsapp.com/*",
    "*://*.youtube.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://blank.org/*",
        "*://*.discord.com/*",
        "*://*.discordapp.com/*",
        "*://*.facebook.com/*",
        "*://*.instagram.com/*",
        "*://*.linkedin.com/*",
        "*://*.pinterest.com/*",
        "*://*.messenger.com/*",
        "*://*.quora.com/*",
        "*://*.reddit.com/*",
        "*://*.slack.com/*",
        "*://*.snapchat.com/*",
        "*://*.telegram.org/*",
        "*://*.tiktok.com/*",
        "*://*.twitch.tv/*",
        "*://*.twitter.com/*",
        "*://*.tumblr.com/*",
        "*://*.whatsapp.com/*",
        "*://*.youtube.com/*"
      ],
      "js": ["src/content.ts"]
    }
  ]
}
