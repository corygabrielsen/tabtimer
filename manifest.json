{
  "manifest_version": 3,
  "name": "Tab Timer",
  "short_name": "Tab Timer",
  "description": "See how much time you've spent on social media sites today.",
  "version": "1.0",
  "author": {
    "email": "corygabrielsen@gmail.com"
  },
  "homepage_url": "https://github.com/corygabrielsen/tabtimer",
  "minimum_chrome_version": "110",
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Tab Timer",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "*://*.discord.com/*",
    "*://*.discordapp.com/*",
    "*://*.facebook.com/*",
    "*://*.instagram.com/*",
    "*://*.linkedin.com/*",
    "*://*.pinterest.com/*",
    "*://*.messenger.com/*",
    "*://*.quora.com/*",
    "*://*.reddit.com/*",
    "*://*.slack.com/*",
    "*://*.snapchat.com/*",
    "*://*.telegram.org/*",
    "*://*.tiktok.com/*",
    "*://*.twitch.tv/*",
    "*://*.twitter.com/*",
    "*://x.com/*",
    "*://*.x.com/*",
    "*://*.tumblr.com/*",
    "*://*.whatsapp.com/*",
    "*://*.youtube.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.discord.com/*",
        "*://*.discordapp.com/*",
        "*://*.facebook.com/*",
        "*://*.instagram.com/*",
        "*://*.linkedin.com/*",
        "*://*.pinterest.com/*",
        "*://*.messenger.com/*",
        "*://*.quora.com/*",
        "*://*.reddit.com/*",
        "*://*.slack.com/*",
        "*://*.snapchat.com/*",
        "*://*.telegram.org/*",
        "*://*.tiktok.com/*",
        "*://*.twitch.tv/*",
        "*://*.twitter.com/*",
        "*://x.com/*",
        "*://*.x.com/*",
        "*://*.tumblr.com/*",
        "*://*.whatsapp.com/*",
        "*://*.youtube.com/*"
      ],
      "js": ["src/content.ts"]
    }
  ]
}
